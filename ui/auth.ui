<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name auth.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkApplicationWindow" id="ChlorineAuth">
    <property name="title">Login - Chlorine</property>
    <property name="visible">true</property>
    <child>
      <object class="GtkBox">
        <property name="margin-bottom">32</property>
        <property name="margin-end">32</property>
        <property name="margin-start">32</property>
        <property name="margin-top">32</property>
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="valign">center</property>
        <child type="center">
          <object class="GtkImage">
            <property name="icon-name">rotur-symbolic</property>
            <property name="pixel-size">64</property>
          </object>
        </child>
        <child type="end">
          <object class="GtkLabel">
            <property name="css-classes">title-2</property>
            <property name="justify">center</property>
            <property name="label">Welcome back!</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel">
            <property name="label">Please authenticate with Rotur via account link</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="code_label">
            <property name="label">Code: ...</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="linking_button">
            <property name="halign">center</property>
            <property name="label">Open Linking Page</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
