<interface>
  <!-- interface-name main.ui -->
  <requires lib="gtk" version="4.6"/>
  <object class="GtkApplicationWindow" id="ChlorineMain">
    <child>
      <object class="GtkBox">
        <property name="halign">center</property>
        <property name="margin-bottom">64</property>
        <property name="margin-end">64</property>
        <property name="margin-start">64</property>
        <property name="margin-top">64</property>
        <child>
          <object class="GtkLabel">
            <property name="justify">center</property>
            <property name="label">Stub UI</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
